// Enhanced AI Assistant Store - Modern State Management with Advanced Features
import { create } from 'zustand';
import { subscribeWithSelector, persist, devtools } from 'zustand/middleware';
import { immer } from 'zustand/middleware/immer';
import AIService from '../services/aiService';

// Store state shape
const initialState = {
  // UI State
  isOpen: false,
  isMinimized: false,
  isLoading: false,
  isTyping: false,
  
  // Chat State
  messages: [],
  currentMessage: '',
  messageHistory: [],
  
  // Context State
  currentContext: {
    page: 'home',
    userId: null,
    courseId: null,
    lessonId: null,
    userProgress: {},
    learningStyle: null,
    sessionData: {},
    timestamp: null
  },
  
  // Assistant State
  assistantMode: 'chat', // 'chat', 'explanation', 'feedback', 'suggestions'
  suggestedActions: [],
  lastResponse: null,
  conversationSummary: '',
  
  // Advanced Features
  preferences: {
    theme: 'auto',
    soundEnabled: true,
    voiceEnabled: false,
    animationsEnabled: true,
    compactMode: false,
    autoScroll: true,
    messageTimestamps: true,
    smartSuggestions: true
  },
  
  // Analytics & Performance
  analytics: {
    sessionStartTime: null,
    totalMessages: 0,
    averageResponseTime: 0,
    userSatisfaction: null,
    mostUsedFeatures: {},
    errorCount: 0
  },
  
  // Error State
  error: null,
  errorHistory: [],
  
  // Performance
  cache: new Map(),
  requestQueue: [],
  retryAttempts: {}
};

// Create store with middleware
export const useAIAssistantStore = create(
  devtools(
    persist(
      subscribeWithSelector(
        immer((set, get) => ({
          ...initialState,
          
          // Core Actions
          toggleAssistant: () => set((state) => {
            state.isOpen = !state.isOpen;
            state.error = null;
            
            if (state.isOpen && !state.analytics.sessionStartTime) {
              state.analytics.sessionStartTime = Date.now();
            }
          }),
          
          minimizeAssistant: () => set((state) => {
            state.isMinimized = true;
          }),
          
          maximizeAssistant: () => set((state) => {
            state.isMinimized = false;
          }),
          
          closeAssistant: () => set((state) => {
            state.isOpen = false;
            state.isMinimized = false;
            state.error = null;
          }),
          
          // Message Management
          setCurrentMessage: (message) => set((state) => {
            state.currentMessage = message;
          }),
          
          addMessage: (message) => set((state) => {
            const newMessage = {
              id: `msg_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,
              timestamp: new Date().toISOString(),
              context: state.currentContext,
              ...message
            };
            
            state.messages.push(newMessage);
            state.analytics.totalMessages += 1;
            
            // Keep message history for context
            if (state.messageHistory.length > 50) {
              state.messageHistory.shift();
            }
            state.messageHistory.push(newMessage);
          }),
          
          updateMessage: (messageId, updates) => set((state) => {
            const messageIndex = state.messages.findIndex(msg => msg.id === messageId);
            if (messageIndex !== -1) {
              Object.assign(state.messages[messageIndex], updates);
            }
          }),
          
          deleteMessage: (messageId) => set((state) => {
            state.messages = state.messages.filter(msg => msg.id !== messageId);
          }),
          
          clearMessages: () => set((state) => {
            state.messages = [];
            state.conversationSummary = '';
          }),
          
          // Context Management
          updateContext: (newContext) => set((state) => {
            state.currentContext = {
              ...state.currentContext,
              ...newContext,
              timestamp: new Date().toISOString()
            };
          }),
          
          setAssistantMode: (mode) => set((state) => {
            state.assistantMode = mode;
            state.error = null;
            
            // Track mode usage
            if (!state.analytics.mostUsedFeatures[mode]) {
              state.analytics.mostUsedFeatures[mode] = 0;
            }
            state.analytics.mostUsedFeatures[mode] += 1;
          }),
          
          // Preferences Management
          updatePreferences: (updates) => set((state) => {
            Object.assign(state.preferences, updates);
          }),
          
          // Error Management
          setError: (error) => set((state) => {
            state.error = error;
            state.analytics.errorCount += 1;
            
            // Add to error history
            state.errorHistory.push({
              error,
              timestamp: new Date().toISOString(),
              context: state.currentContext
            });
            
            // Keep error history manageable
            if (state.errorHistory.length > 20) {
              state.errorHistory.shift();
            }
          }),
          
          clearError: () => set((state) => {
            state.error = null;
          }),
          
          // Advanced Chat Functions
          sendMessage: async (message) => {
            const state = get();
            
            if (!message.trim()) return;
            
            const requestId = `req_${Date.now()}`;
            const startTime = Date.now();
            
            try {
              set((state) => {
                state.isLoading = true;
                state.error = null;
                state.currentMessage = '';
              });
              
              // Add user message
              get().addMessage({
                type: 'user',
                content: message,
                mode: state.assistantMode
              });
              
              // Check cache first
              const cacheKey = `${state.assistantMode}_${message}_${JSON.stringify(state.currentContext)}`;
              if (state.cache.has(cacheKey)) {
                const cachedResponse = state.cache.get(cacheKey);
                get().addMessage(cachedResponse);
                return cachedResponse;
              }
              
              // Send to AI service
              const response = await AIService.chat({
                message,
                context: {
                  ...state.currentContext,
                  mode: state.assistantMode,
                  messageHistory: state.messageHistory.slice(-10), // Last 10 messages for context
                  preferences: state.preferences
                }
              });
              
              // Calculate response time
              const responseTime = Date.now() - startTime;
              
              // Add AI response
              const aiMessage = {
                type: 'assistant',
                content: response.response,
                metadata: {
                  ...response.metadata,
                  mode: state.assistantMode,
                  responseTime,
                  requestId
                },
                suggestions: response.suggestions || [],
                recommendations: response.recommendations || []
              };
              
              get().addMessage(aiMessage);
              
              // Cache successful response
              state.cache.set(cacheKey, aiMessage);
              if (state.cache.size > 100) {
                const firstKey = state.cache.keys().next().value;
                state.cache.delete(firstKey);
              }
              
              // Update analytics
              set((state) => {
                const totalResponses = state.analytics.totalMessages / 2; // Rough estimate
                state.analytics.averageResponseTime = 
                  (state.analytics.averageResponseTime * (totalResponses - 1) + responseTime) / totalResponses;
              });
              
              // Update suggested actions if provided
              if (response.suggestedActions) {
                set((state) => {
                  state.suggestedActions = response.suggestedActions;
                });
              }
              
              set((state) => {
                state.lastResponse = response;
              });
              
              return response;
              
            } catch (error) {
              console.error('Send message error:', error);
              
              // Handle retry logic
              const retryKey = `${requestId}_retry`;
              const currentRetries = state.retryAttempts[retryKey] || 0;
              
              if (currentRetries < 3) {
                // Add to retry queue
                set((state) => {
                  state.retryAttempts[retryKey] = currentRetries + 1;
                  state.requestQueue.push({
                    id: requestId,
                    message,
                    timestamp: Date.now(),
                    retryCount: currentRetries + 1
                  });
                });
                
                // Retry after delay
                setTimeout(() => {
                  get().sendMessage(message);
                }, Math.pow(2, currentRetries) * 1000); // Exponential backoff
                
                return;
              }
              
              // Max retries reached, show error
              get().setError(`Failed to send message: ${error.message}`);
              
              // Add error message
              get().addMessage({
                type: 'error',
                content: 'Sorry, I encountered an error. Please try again.',
                error: error.message,
                metadata: {
                  requestId,
                  retryCount: currentRetries
                }
              });
              
              throw error;
            } finally {
              set((state) => {
                state.isLoading = false;
              });
            }
          },
          
          // Streaming message support
          sendStreamingMessage: async (message) => {
            const state = get();
            
            if (!message.trim()) return;
            
            try {
              set((state) => {
                state.isLoading = true;
                state.isTyping = true;
                state.error = null;
                state.currentMessage = '';
              });
              
              // Add user message
              get().addMessage({
                type: 'user',
                content: message,
                mode: state.assistantMode
              });
              
              // Add placeholder for AI response
              const responseId = get().addMessage({
                type: 'assistant',
                content: '',
                isStreaming: true
              });
              
              // Stream response
              await AIService.streamChat({
                message,
                context: {
                  ...state.currentContext,
                  mode: state.assistantMode,
                  messageHistory: state.messageHistory.slice(-10)
                },
                onChunk: (chunk, fullText) => {
                  get().updateMessage(responseId, {
                    content: fullText
                  });
                }
              });
              
              // Mark streaming as complete
              get().updateMessage(responseId, {
                isStreaming: false
              });
              
            } catch (error) {
              console.error('Streaming message error:', error);
              get().setError(error.message);
              
              // Add error message
              get().addMessage({
                type: 'error',
                content: 'Sorry, I encountered an error. Please try again.',
                error: error.message
              });
            } finally {
              set((state) => {
                state.isLoading = false;
                state.isTyping = false;
              });
            }
          },
          
          // Suggested Actions Management
          setSuggestedActions: (actions) => set((state) => {
            state.suggestedActions = actions.map(action => ({
              id: `action_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,
              timestamp: new Date().toISOString(),
              ...action
            }));
          }),
          
          executeSuggestedAction: async (action) => {
            const state = get();
            
            try {
              set((state) => {
                state.isLoading = true;
                state.error = null;
              });
              
              switch (action.type) {
                case 'chat':
                  await get().sendMessage(action.message);
                  break;
                case 'explain':
                  await get().explainContent(action.content, action.level);
                  break;
                case 'recommend':
                  await get().getRecommendations();
                  break;
                default:
                  console.warn('Unknown action type:', action.type);
              }
              
              // Track action usage
              set((state) => {
                const actionType = `action_${action.type}`;
                if (!state.analytics.mostUsedFeatures[actionType]) {
                  state.analytics.mostUsedFeatures[actionType] = 0;
                }
                state.analytics.mostUsedFeatures[actionType] += 1;
              });
              
            } catch (error) {
              console.error('Execute action error:', error);
              get().setError(error.message);
            } finally {
              set((state) => {
                state.isLoading = false;
              });
            }
          },
          
          // AI Service Integration
          getRecommendations: async () => {
            const state = get();
            
            try {
              set((state) => {
                state.isLoading = true;
                state.error = null;
              });
              
              const response = await AIService.getRecommendations({
                userId: state.currentContext.userId,
                context: state.currentContext
              });
              
              get().addMessage({
                type: 'assistant',
                content: response.response,
                recommendations: response.recommendations || [],
                metadata: { type: 'recommendations' }
              });
              
              return response;
              
            } catch (error) {
              console.error('Get recommendations error:', error);
              get().setError(error.message);
              throw error;
            } finally {
              set((state) => {
                state.isLoading = false;
              });
            }
          },
          
          explainContent: async (content, level = 'intermediate') => {
            const state = get();
            
            try {
              set((state) => {
                state.isLoading = true;
                state.error = null;
              });
              
              const response = await AIService.explainContent({
                content,
                level,
                context: state.currentContext
              });
              
              get().addMessage({
                type: 'assistant',
                content: response.response,
                metadata: { type: 'explanation', content, level }
              });
              
              return response;
              
            } catch (error) {
              console.error('Explain content error:', error);
              get().setError(error.message);
              throw error;
            } finally {
              set((state) => {
                state.isLoading = false;
              });
            }
          },
          
          // Analytics and Feedback
          recordFeedback: (messageId, feedbackType, details = {}) => set((state) => {
            const message = state.messages.find(msg => msg.id === messageId);
            if (message) {
              message.feedback = {
                type: feedbackType,
                timestamp: new Date().toISOString(),
                ...details
              };
              
              // Update satisfaction metrics
              if (feedbackType === 'positive') {
                state.analytics.userSatisfaction = 
                  ((state.analytics.userSatisfaction || 0) * 0.9 + 1 * 0.1);
              } else if (feedbackType === 'negative') {
                state.analytics.userSatisfaction = 
                  ((state.analytics.userSatisfaction || 0) * 0.9 + 0 * 0.1);
              }
            }
          }),
          
          // Utility Functions
          exportChatHistory: () => {
            const state = get();
            return {
              messages: state.messages,
              context: state.currentContext,
              analytics: state.analytics,
              exportedAt: new Date().toISOString()
            };
          },
          
          importChatHistory: (data) => set((state) => {
            if (data.messages) {
              state.messages = data.messages;
            }
            if (data.context) {
              state.currentContext = data.context;
            }
          }),
          
          // Performance optimization
          cleanupOldData: () => set((state) => {
            const oneWeekAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;
            
            // Clean old messages
            state.messageHistory = state.messageHistory.filter(
              msg => new Date(msg.timestamp).getTime() > oneWeekAgo
            );
            
            // Clean old errors
            state.errorHistory = state.errorHistory.filter(
              error => new Date(error.timestamp).getTime() > oneWeekAgo
            );
            
            // Clean old cache entries
            state.cache.clear();
            
            // Reset retry attempts
            state.retryAttempts = {};
          })
          
        }))
      ),
      {
        name: 'ai-assistant-store',
        partialize: (state) => ({
          preferences: state.preferences,
          analytics: state.analytics,
          // Don't persist sensitive or large data
        })
      }
    ),
    {
      name: 'AI Assistant Store'
    }
  )
);

// Auto-cleanup old data every hour
if (typeof window !== 'undefined') {
  setInterval(() => {
    useAIAssistantStore.getState().cleanupOldData();
  }, 60 * 60 * 1000);
}

// Context subscription for auto-suggestions
useAIAssistantStore.subscribe(
  (state) => state.currentContext,
  (context) => {
    const timeoutId = setTimeout(() => {
      if (context.page && context.userId && useAIAssistantStore.getState().preferences.smartSuggestions) {
        // Generate contextual suggestions based on current context
        // This could be enhanced with more sophisticated logic
        const suggestions = generateContextualSuggestions(context);
        if (suggestions.length > 0) {
          useAIAssistantStore.getState().setSuggestedActions(suggestions);
        }
      }
    }, 2000); // Debounce suggestions
    
    return () => clearTimeout(timeoutId);
  }
);

// Helper function to generate contextual suggestions
function generateContextualSuggestions(context) {
  const suggestions = [];
  
  if (context.lessonId) {
    suggestions.push({
      type: 'explain',
      label: 'Explain this lesson',
      message: 'Can you explain the key concepts in this lesson?',
      category: 'learning'
    });
    
    suggestions.push({
      type: 'chat',
      label: 'Practice questions',
      message: 'Give me some practice questions for this topic',
      category: 'practice'
    });
  }
  
  if (context.courseId) {
    suggestions.push({
      type: 'recommend',
      label: 'Study recommendations',
      message: 'What should I focus on for this course?',
      category: 'guidance'
    });
  }
  
  return suggestions;
}

export default useAIAssistantStore;
