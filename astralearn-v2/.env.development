# AstraLearn v2 Development Environment Configuration
# This file contains development-specific settings

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

NODE_ENV=development
APP_NAME=AstraLearn
APP_VERSION=2.0.0

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

PORT=5000
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

DB_TYPE=mongodb
MONGODB_URI=mongodb://localhost:27017/astralearn-v2
MONGODB_URI_TEST=mongodb://localhost:27017/astralearn-v2-test

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# Development JWT secrets (not for production)
JWT_SECRET=dev-jwt-secret-not-for-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-not-for-production
JWT_REFRESH_EXPIRES_IN=30d

# Lower security for development
BCRYPT_ROUNDS=10

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_ENABLED=true

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-dev-email@gmail.com
SMTP_PASS=your-dev-app-password
FROM_EMAIL=dev@astralearn.com
FROM_NAME=AstraLearn Dev

# =============================================================================
# FILE STORAGE
# =============================================================================

STORAGE_TYPE=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,ppt,pptx

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# AI Configuration (development keys)
GROQ_API_KEY=your-dev-groq-api-key
OPENAI_API_KEY=your-dev-openai-api-key

# Stripe Test Keys
STRIPE_PUBLISHABLE_KEY=pk_test_your-test-stripe-key
STRIPE_SECRET_KEY=sk_test_your-test-stripe-key

# Analytics (development)
GOOGLE_ANALYTICS_ID=GA-DEV-XXXXXXXXX

# =============================================================================
# SECURITY & RATE LIMITING
# =============================================================================

# Relaxed rate limiting for development
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
CORS_ORIGIN=http://localhost:3000
HELMET_ENABLED=false

# SSL disabled for development
SSL_ENABLED=false

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

LOG_LEVEL=debug
LOG_FILE=logs/dev.log

# No error tracking in development
SENTRY_DSN=

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# All features enabled for development
FEATURE_DISCUSSIONS=true
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_ANALYTICS=true
FEATURE_CERTIFICATES=true
FEATURE_PAYMENTS=false
FEATURE_LIVE_SESSIONS=false

# Development features enabled
ENABLE_API_DOCS=true
ENABLE_DEV_TOOLS=true
USE_MOCK_DATA=false

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

VITE_API_URL=http://localhost:5000
VITE_WEBSOCKET_URL=http://localhost:5000
VITE_APP_NAME=AstraLearn Dev
VITE_APP_VERSION=2.0.0

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Debug settings
DEBUG=true
VERBOSE_LOGGING=true

# Hot reload
HOT_RELOAD=true

# Development database seeding
SEED_DATABASE=true
SEED_SAMPLE_DATA=true

# =============================================================================
# TESTING
# =============================================================================

# Test configuration
TEST_PORT=5001
TEST_JWT_SECRET=test-jwt-secret
TEST_DB_URI=mongodb://localhost:27017/astralearn-v2-test

# =============================================================================
# PERFORMANCE (relaxed for development)
# =============================================================================

# Database settings
DB_POOL_SIZE=5
DB_TIMEOUT=10000

# Caching (shorter TTL for development)
CACHE_TTL=300
CACHE_MAX_SIZE=100

# Compression disabled for easier debugging
COMPRESSION_ENABLED=false

# =============================================================================
# HEALTH CHECK
# =============================================================================

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
