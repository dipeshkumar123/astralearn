{
  "name": "astralearn-v2",
  "version": "2.0.0",
  "description": "AstraLearn - AI-Powered Social Learning Platform (Complete Rebuild)",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm run install:client && npm run install:server && npm run install:shared",
    "install:client": "cd client && npm install",
    "install:server": "cd server && npm install",
    "install:shared": "cd shared && npm install",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:shared": "cd shared && npm run dev",
    "build": "npm run build:shared && npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build:shared": "cd shared && npm run build",
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:client": "cd client && npm run start",
    "start:server": "cd server && npm run start",
    "start:prod": "cd server && npm run start:prod",
    "test": "npm run test:shared && npm run test:server && npm run test:client",
    "test:client": "cd client && npm run test",
    "test:server": "cd server && npm run test",
    "test:shared": "cd shared && npm run test",
    "test:e2e": "cd client && npm run test:e2e",
    "lint": "npm run lint:client && npm run lint:server && npm run lint:shared",
    "lint:client": "cd client && npm run lint",
    "lint:server": "cd server && npm run lint",
    "lint:shared": "cd shared && npm run lint",
    "lint:fix": "npm run lint:fix:client && npm run lint:fix:server && npm run lint:fix:shared",
    "lint:fix:client": "cd client && npm run lint:fix",
    "lint:fix:server": "cd server && npm run lint:fix",
    "lint:fix:shared": "cd shared && npm run lint:fix",
    "type-check": "npm run type-check:client && npm run type-check:server && npm run type-check:shared",
    "type-check:client": "cd client && npm run type-check",
    "type-check:server": "cd server && npm run type-check",
    "type-check:shared": "cd shared && npm run type-check",
    "clean": "npm run clean:client && npm run clean:server && npm run clean:shared",
    "clean:client": "cd client && npm run clean",
    "clean:server": "cd server && npm run clean",
    "clean:shared": "cd shared && npm run clean",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "seed": "cd server && npm run seed",
    "seed:dev": "cd server && npm run seed:dev",
    "seed:prod": "cd server && npm run seed:prod",
    "migrate": "cd server && npm run migrate",
    "migrate:rollback": "cd server && npm run migrate:rollback",
    "start:full-test": "node unified-startup-test.js",
    "start:production": "node production-startup.js",
    "test:comprehensive": "node backend-focused-test.js",
    "test:backend-only": "node comprehensive-backend-tests.js",
    "test:performance": "node comprehensive-performance-tests.js",
    "start:backend-direct": "cd server && node simple-test-server.cjs",
    "start:frontend-direct": "cd client && npm start"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^30.0.5",
    "playwright": "^1.54.1",
    "prettier": "^3.1.0",
    "puppeteer": "^24.14.0",
    "supertest": "^7.1.4",
    "typescript": "^5.3.0",
    "wait-on": "^8.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dipeshkumar123/astralearn-v2.git"
  },
  "keywords": [
    "education",
    "learning",
    "ai",
    "social-learning",
    "adaptive-learning",
    "gamification",
    "react",
    "nodejs",
    "mongodb",
    "typescript"
  ],
  "author": "Dipesh Kumar Panjiyar <panjiyardipesh123@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dipeshkumar123/astralearn-v2/issues"
  },
  "homepage": "https://github.com/dipeshkumar123/astralearn-v2#readme",
  "dependencies": {
    "crypto": "^1.0.1",
    "openai": "^5.10.2",
    "pdfkit": "^0.17.1",
    "qrcode": "^1.5.4"
  }
}
