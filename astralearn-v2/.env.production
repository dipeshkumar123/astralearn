# AstraLearn v2 Production Environment Configuration
# This file contains production-ready settings

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

NODE_ENV=production
APP_NAME=AstraLearn
APP_VERSION=2.0.0

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

PORT=443
FRONTEND_URL=https://astralearn.com
API_BASE_URL=https://api.astralearn.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

DB_TYPE=mongodb
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/astralearn?retryWrites=true&w=majority

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# Strong JWT secrets (generate with: openssl rand -base64 64)
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_STRONG_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# Enhanced security for production
BCRYPT_ROUNDS=14

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_URL=redis://your-redis-instance:6379
REDIS_PASSWORD=your-redis-password
REDIS_ENABLED=true

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@astralearn.com
FROM_NAME=AstraLearn

# =============================================================================
# FILE STORAGE
# =============================================================================

STORAGE_TYPE=aws-s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=astralearn-production-uploads

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

OPENAI_API_KEY=your-production-openai-api-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-live-stripe-publishable-key
STRIPE_SECRET_KEY=sk_live_your-live-stripe-secret-key
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# =============================================================================
# SECURITY & RATE LIMITING
# =============================================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50
CORS_ORIGIN=https://astralearn.com
HELMET_ENABLED=true

# SSL Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/astralearn.crt
SSL_KEY_PATH=/etc/ssl/private/astralearn.key

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

LOG_LEVEL=warn
LOG_FILE=/var/log/astralearn/app.log
SENTRY_DSN=your-production-sentry-dsn

# =============================================================================
# FEATURE FLAGS
# =============================================================================

FEATURE_DISCUSSIONS=true
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_ANALYTICS=true
FEATURE_CERTIFICATES=true
FEATURE_PAYMENTS=true
FEATURE_LIVE_SESSIONS=true

# Development features disabled in production
ENABLE_API_DOCS=false
ENABLE_DEV_TOOLS=false
USE_MOCK_DATA=false

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

VITE_API_URL=https://api.astralearn.com
VITE_WEBSOCKET_URL=https://ws.astralearn.com
VITE_APP_NAME=AstraLearn
VITE_APP_VERSION=2.0.0

# =============================================================================
# BACKUP & MAINTENANCE
# =============================================================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
MAINTENANCE_MODE=false

# =============================================================================
# PERFORMANCE
# =============================================================================

# Database connection pooling
DB_POOL_SIZE=10
DB_TIMEOUT=30000

# Caching
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
