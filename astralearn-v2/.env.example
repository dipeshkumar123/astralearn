# AstraLearn v2 Environment Configuration Template
# Copy this file to .env and update the values for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Application Name and Version
APP_NAME=AstraLearn
APP_VERSION=2.0.0

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# API Base URL
API_BASE_URL=http://localhost:5000/api

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database Type (mongodb, postgresql, mysql)
DB_TYPE=mongodb

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/astralearn-v2
MONGODB_URI_TEST=mongodb://localhost:27017/astralearn-v2-test

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Password Hashing Rounds
BCRYPT_ROUNDS=12

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

# Redis URL
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_ENABLED=true

# AI Configuration
GROQ_API_KEY=your-groq-api-key-here

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info

# Frontend Configuration (for build-time)
VITE_API_URL=http://localhost:5000
VITE_WEBSOCKET_URL=http://localhost:5000
VITE_APP_NAME=AstraLearn
VITE_APP_VERSION=2.0.0

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Core Features
FEATURE_DISCUSSIONS=true
FEATURE_AI_RECOMMENDATIONS=true
FEATURE_ANALYTICS=true
FEATURE_CERTIFICATES=true

# Advanced Features
FEATURE_PAYMENTS=false
FEATURE_LIVE_SESSIONS=false
FEATURE_MOBILE_APP=false

# Development Features
ENABLE_API_DOCS=true
ENABLE_DEV_TOOLS=true
USE_MOCK_DATA=false

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================

# OpenAI for AI Features
OPENAI_API_KEY=your-openai-api-key

# Stripe for Payments
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Google Analytics
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Production Environment (uncomment for production)
# NODE_ENV=production
# PORT=443

# Production Database
# MONGODB_URI=mongodb://your-production-db-url

# Production Security
# JWT_SECRET=your-super-secure-production-jwt-secret
# BCRYPT_ROUNDS=14

# Production CORS
# CORS_ORIGIN=https://your-domain.com

# Production Frontend URLs
# VITE_API_URL=https://api.your-domain.com
# VITE_WEBSOCKET_URL=https://ws.your-domain.com

# SSL Configuration
# SSL_ENABLED=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Error Tracking (Sentry)
# SENTRY_DSN=your-sentry-dsn

# Performance Monitoring
# NEW_RELIC_LICENSE_KEY=your-new-relic-key

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
