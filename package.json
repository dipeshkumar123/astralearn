{
  "name": "astralearn",
  "version": "1.0.0",
  "description": "Advanced LMS with Context-Aware AI",
  "main": "index.js",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "install:all": "npm install && npm install --workspaces",
    "setup:dev": "node scripts/development/setup.js",
    "seed:comprehensive": "node server/src/scripts/comprehensiveSeed.js",
    "seed:simple": "node server/src/scripts/seedSampleData.js",
    "simulate:realtime": "node server/src/scripts/realTimeSimulator.js",
    "validate:system": "node scripts/validateSystem.js",
    "reorganize:project": "node scripts/reorganizeProject.js",
    "test:unit": "npm run test --workspaces",
    "test:integration": "npm run test:integration --workspace=server",
    "test:e2e": "npm run test:e2e --workspace=client",
    "test:comprehensive": "npm run validate:system",
    "docs:serve": "npx serve docs",
    "clean": "npm run clean --workspaces",
    "reset": "npm run clean && npm run install:all && npm run setup:dev",
    "production:build": "NODE_ENV=production npm run build",
    "production:deploy": "docker-compose -f docker-compose.prod.yml up -d"
  },
  "keywords": [
    "lms",
    "ai",
    "education",
    "learning",
    "context-aware"
  ],
  "author": "AstraLearn Team",
  "license": "MIT",
  "devDependencies": {
    "artillery": "^2.0.21",
    "chai": "^5.2.0",
    "compression": "^1.8.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "helmet": "^8.1.0",
    "mocha": "^11.6.0",
    "prettier": "^3.2.5",
    "supertest": "^7.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
