{
  "name": "astralearn",
  "version": "1.0.0",
  "description": "Advanced LMS with Context-Aware AI",
  "main": "index.js",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "install:all": "npm install && npm install --workspaces"
  },
  "keywords": [
    "lms",
    "ai",
    "education",
    "learning",
    "context-aware"
  ],
  "author": "AstraLearn Team",
  "license": "MIT",
  "devDependencies": {
    "artillery": "^2.0.21",
    "chai": "^5.2.0",
    "compression": "^1.8.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "helmet": "^8.1.0",
    "mocha": "^11.6.0",
    "prettier": "^3.2.5",
    "supertest": "^7.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
